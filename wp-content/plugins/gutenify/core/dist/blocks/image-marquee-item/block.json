{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gutenify/image-marquee-item",
  "category": "gutenify",
  "parent": [
    "gutenify/image-marquee"
  ],
  "title": "Marquee Item",
  "description": "Individual item for the image marquee.",
  "version": "1",
  "attributes": {
    "blockClientId": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "html": true,
    "anchor": true,
    "inserter": false,
    "color": {
      "background": true,
      "text": true,
      "link": true,
      "gradients": true
    },
    "spacing": {
      "margin": true,
      "padding": true,
      "__experimentalDefaultControls": {
        "margin": true,
        "padding": true
      }
    },
    "shadow": true,
    "__experimentalBorder": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true,
      "__experimentalDefaultControls": {
        "color": true,
        "radius": true,
        "style": true,
        "width": true
      }
    }
  },
  "editorScript": [
    "file:./index.js"
  ],
  "style": [
    "file:./style-index.css"
  ]
}